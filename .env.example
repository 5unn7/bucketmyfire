# Global leaderboard + cloud progress saves (optional) — Supabase.
#
# These same two vars power BOTH the global leaderboard AND passwordless cloud progress
# saves (restore your campaign by pilot name + email — see src/three/leaderboard/cloudSave.ts).
#
# 1. Create a free project at https://supabase.com
# 2. Run supabase/schema.sql in the project's SQL editor (creates the scores table,
#    row-level-security policies, the leaderboard views, and the locked cloud_saves
#    table + its two SECURITY DEFINER save/load functions).
# 3. Copy this file to `.env` and paste your Project URL + anon (public) key below.
#
# Both values come from: Supabase dashboard → Project Settings → API.
# The anon key is the PUBLIC, RLS-gated key and is safe to ship in a static bundle.
# Leave either blank and the game runs exactly as before, with the leaderboard "offline".

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Crash/error beacon (optional). When set, uncaught errors + unhandled promise rejections are
# POSTed here as compact, PII-free JSON (error name/message, trimmed stack, WebGL availability,
# viewport, user-agent) via navigator.sendBeacon — so launch-day breakage on the long tail of
# devices is visible instead of silent. Point it at any endpoint that accepts a JSON POST
# (a Cloudflare Worker, a logging service, a Supabase edge function). Leave blank → errors are
# logged to the browser console only (no network call).
VITE_ERROR_BEACON_URL=

# Live wildfire tracker (on by default). The home screen pulls TODAY'S real Saskatchewan wildfire
# hotspots (last 24h) from the public CWFIS service (Natural Resources Canada) — no key, no backend,
# CORS-open, and fully best-effort (it degrades to an "offline" tracker on any failure). Set this to
# `1` as an incident kill-switch to disable the network call entirely (the banner then reads offline).
VITE_LIVEFIRE_DISABLE=
