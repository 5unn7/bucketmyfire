{
  "name": "bucketmyfire",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-browser helicopter simulator: fight forest fires in northern Saskatchewan with a Bambi bucket.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:campaign": "esbuild scripts/verify-campaign.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-campaign.mjs --log-level=warning && node scripts/.verify-campaign.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,html,css}\""
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
