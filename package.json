{
  "name": "bucketmyfire",
  "version": "0.1.0",
  "private": true,
  "description": "In-browser helicopter wildfire flight sim: fill from the lakes and fight the fire before it reaches the town.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:campaign": "esbuild scripts/verify-campaign.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-campaign.mjs --log-level=warning && node scripts/.verify-campaign.mjs",
    "verify:crash": "esbuild scripts/verify-crash.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-crash.mjs --log-level=warning && node scripts/.verify-crash.mjs",
    "verify:voice": "esbuild scripts/verify-voice.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-voice.mjs --log-level=warning && node scripts/.verify-voice.mjs",
    "verify:feel": "esbuild scripts/verify-feel.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-feel.mjs --log-level=warning && node scripts/.verify-feel.mjs",
    "verify:world": "esbuild scripts/verify-world.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-world.mjs --log-level=warning && node scripts/.verify-world.mjs",
    "verify:coach": "esbuild scripts/verify-coach.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-coach.mjs --log-level=warning && node scripts/.verify-coach.mjs",
    "verify:province": "esbuild scripts/verify-province.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-province.mjs --log-level=warning && node scripts/.verify-province.mjs",
    "verify:ui": "node scripts/verify-ui.mjs",
    "verify:render": "node scripts/verify-render.mjs",
    "gen:tokens": "esbuild scripts/gen-tokens.ts --bundle --platform=node --format=esm --outfile=scripts/.gen-tokens.mjs --log-level=warning && node scripts/.gen-tokens.mjs",
    "verify:tokens": "esbuild scripts/gen-tokens.ts --bundle --platform=node --format=esm --outfile=scripts/.gen-tokens.mjs --log-level=warning && node scripts/.gen-tokens.mjs --check",
    "verify": "npm run verify:campaign && npm run verify:crash && npm run verify:voice && npm run verify:feel && npm run verify:world && npm run verify:coach && npm run verify:province && npm run verify:ui && npm run verify:tokens",
    "verify:all": "npm run verify && npm run verify:render",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "bake:heightmap": "node scripts/bake-heightmap.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/saira": "^5.2.11",
    "@supabase/realtime-js": "^2.107.0",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.0",
    "meshoptimizer": "^1.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "typescript": "^5.5.4",
    "vite": "^7.3.5"
  }
}
